# ── Application ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# PostgreSQL (shared instance)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# DSP application database
DSP_DB_NAME=dsp
DSP_DB_USER=dsp
DSP_DB_PASSWORD=dsp
DATABASE_URL=postgresql://dsp:dsp@postgres:5432/dsp

# Airflow metadata database
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# Model service
MODEL_VERSION=1.0.0
MODELS_DIR=/app/models

# Webapp
API_URL=http://model_service:8000

# Airflow
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Data directories (inside containers)
RAW_DATA_DIR=/data/raw
GOOD_DATA_DIR=/data/good
BAD_DATA_DIR=/data/bad
PROCESSED_DATA_DIR=/data/processed
PREDICTED_DATA_DIR=/data/predicted

# Model service URL (used by Airflow prediction DAG)
MODEL_SERVICE_URL=http://model_service:8000
